# Get your key from https://aistudio.google.com/apikey
GEMINI_API_KEY=your_key_here

# Optional: override model. Default is gemini-2.5-flash.
# Other options: gemini-2.5-pro, gemini-2.5-flash-lite
# GEMINI_MODEL=gemini-2.5-flash

# Optional: GCP project (we'll add later when we move to Vertex AI)
# GOOGLE_CLOUD_PROJECT=
# GOOGLE_CLOUD_LOCATION=us-central1

# Composio (for Execution sub-agent's external tools — Gmail, Calendar, Slack, etc.)
# Get from https://dashboard.composio.dev (Settings → API Keys)
COMPOSIO_API_KEY=
COMPOSIO_USER_ID=

# Slack delivery for the "scan my book" pipeline (optional but recommended).
# Create a Slack app → Incoming Webhooks → add to your channel, paste the URL here.
# Without it the pipeline still completes and prints formatted Slack blocks.
SLACK_WEBHOOK_URL=
SLACK_CHANNEL=#general

# Telegram delivery (optional, 2 minutes): message @BotFather → /newbot → paste
# the token; then message @userinfobot to get your chat id. Scan digests land
# on your phone.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=